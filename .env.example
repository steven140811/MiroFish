# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 这里配置的是本体生成、模拟参数生成、Agent画像生成、报告生成等 LLM 推理模型。
# 注意：Zep 是图谱/检索后端，不是 LLM 模型，不能直接用 LLM_MODEL_NAME 替代。
# 如使用通用 OpenAI 兼容网关，优先选择结构化输出和中文长文本能力更稳的通用模型。
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ===== 本地服务端口配置 =====
# 前端开发服务端口（Vite 会读取项目根目录 .env）
FRONTEND_PORT=3001
# 后端 Flask 端口
FLASK_PORT=5001
# 图谱后端；默认使用本地 SQLite 图谱库
GRAPH_BACKEND=local
# 本地图谱数据库路径；建议放在 D 盘或项目目录所在磁盘
GRAPH_DB_PATH=D:/Mirofish/data/local_graph.db
# 如需前端直接请求独立后端地址，可显式指定；留空时默认走 /api 代理
# VITE_API_BASE_URL=http://localhost:5001

# ===== ZEP记忆图谱配置 =====
# Zep 负责图谱构建、实体/关系检索、历史事实读取和图谱更新，不是可替换的模型参数。
# 未配置时后端仍可启动，但图谱构建、实体读取和报告深度分析等依赖 Zep 的能力不可用。
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here